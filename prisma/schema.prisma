datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Week {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  isFinal   Boolean  @default(false)

  label     String
  eventName String
  eventYear Int
  eventId   String
  tour      String   @default("pga")

  bets      Bet[]

  @@index([createdAt])
  @@unique([eventId, tour], name: "eventId_tour")
}

model Bet {
  id                 Int      @id @default(autoincrement())
  weekId             Int
  week               Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)

  placedAtUtc        String?
  betType            String
  tour               String   @default("pga")
  playerName         String
  dgId               Int?
  marketBookBest     String?
  marketOddsBestDec  Float?
  stakeUnits         Float?

  pModel             Float?
  edgeProb           Float?
  evPerUnit          Float?
  kellyFull          Float?
  kellyFrac          Float?

  resultWinFlag      Int?
  returnUnits        Float?

  @@index([weekId])
}

enum BetslipStatus {
  PENDING
  PLACED
}

model BetslipItem {
  id                 String        @id @default(cuid())
  uniqueKey          String        @unique
  eventId            String
  eventName          String
  eventYear          Int
  tour               String        @default("pga")
  market             String
  playerName         String
  dgId               String?
  opponents          String?
  marketBookBest     String?
  marketOddsBestDec  Float?
  oddsEnteredDec     Float?
  pModel             Float?
  edgeProb           Float?
  evPerUnit          Float?
  kellyFull          Float?
  kellyFrac          Float?
  stakeUnits         Float?
  status             BetslipStatus @default(PENDING)
  archivedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model EventSnapshot {
  id         String   @id @default(cuid())
  tour       String
  eventId    String
  eventName  String
  eventYear  Int
  capturedAt DateTime
  createdAt  DateTime @default(now())

  @@index([tour, eventId, capturedAt])
}

model OddsSnapshot {
  id         String   @id @default(cuid())
  tour       String
  eventId    String
  eventYear  Int
  market     String
  book       String
  dgId       Int?
  playerName String?
  oddsDec    Float?
  marketProb Float?
  opponents  String?
  groupId    String?
  capturedAt DateTime
  createdAt  DateTime @default(now())

  @@index([tour, eventId, market, capturedAt])
}

model EventSg {
  id         String   @id @default(cuid())
  tour       String
  eventId    String
  eventYear  Int
  dgId       Int
  playerName String
  sgOtt      Float?
  sgApp      Float?
  sgArg      Float?
  sgPutt     Float?
  sgTotal    Float?
  rounds     Int?
  createdAt  DateTime @default(now())

  @@unique([tour, eventId, eventYear, dgId], name: "event_sg_unique")
}

model EventResult {
  id         String   @id @default(cuid())
  tour       String
  eventId    String
  eventYear  Int
  dgId       Int
  playerName String
  finishPos  Int?
  earnings   Float?
  createdAt  DateTime @default(now())

  @@unique([tour, eventId, eventYear, dgId], name: "event_result_unique")
}
